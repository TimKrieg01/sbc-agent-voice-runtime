# Copy this file to deploy/vm.env on the VM and fill in your actual values.
# The render script uses these values to generate deploy/rendered/* files.

PUBLIC_SIP_HOST=sip.agentvoiceruntime.com
PUBLIC_MEDIA_HOST=sip.agentvoiceruntime.com
LOCAL_NET=10.0.0.0/8

TLS_CERT_FILE=/etc/asterisk/keys/fullchain.pem
TLS_PRIV_KEY_FILE=/etc/asterisk/keys/privkey.pem

ODBC_DSN=asterisk_cfg
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>

ARI_USER=agentic
ARI_PASSWORD=agentic-secret
ARI_ALLOWED_ORIGINS=*
HTTP_BIND_ADDR=127.0.0.1
HTTP_BIND_PORT=8088

RTP_START=10000
RTP_END=20000

SERVICE_USER=azureuser
SERVICE_GROUP=azureuser
APP_DIR=/home/azureuser/agentic-sip-trunk
VENV_DIR=/home/azureuser/agentic-sip-trunk/.venv
ENV_FILE=/home/azureuser/agentic-sip-trunk/.env
