[Unit]
Description=Agentic SIP AI App
After=network.target

[Service]
User=azureuser
WorkingDirectory=/home/azureuser/agentic-sip-trunk
EnvironmentFile=/home/azureuser/agentic-sip-trunk/.env
ExecStart=/home/azureuser/agentic-sip-trunk/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target

