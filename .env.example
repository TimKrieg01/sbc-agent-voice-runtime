AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
# AZURE_SPEECH_ENDPOINT=wss://your-custom-endpoint (Optional, overriding the region defaults)

# Asterisk ARI bridge settings (used by src.services.sip.ari_bridge)
ASTERISK_ARI_BASE=http://127.0.0.1:8088/ari
ASTERISK_ARI_WS=ws://127.0.0.1:8088/ari/events
ASTERISK_ARI_USER=agentic
ASTERISK_ARI_PASS=agentic-secret
ASTERISK_ARI_APP=agentic

# Local FastAPI control endpoint for SIP session lifecycle
PYTHON_APP_BASE=http://127.0.0.1:8000
SIP_TENANT_ID=default
SIP_STT_ENGINE=azure
SIP_LANGUAGES=en-US

# Optional: strict multi-tenant SIP resolution. If true, unknown/ambiguous calls are rejected.
SIP_STRICT_TENANT_RESOLUTION=true

# Optional: JSON array of tenant trunk rules used by src.core.tenant.resolve_tenant
# Tenant identity is resolved by ingress_hosts only.
# auth_users is optional and enforced only for that host when configured.
# called_numbers can be stored for downstream per-tenant routing logic.
# Example:
# SIP_TENANT_RULES_JSON=[{"tenant_id":"acme","trunk_id":"acme-main","ingress_hosts":["acme.sip.agentvoiceruntime.com"],"called_numbers":["+49123456789"],"auth_users":["acme-auth"],"stt_engine":"azure","languages":["en-US","de-DE"],"backend_url":"https://api.acme.ai/calls/inbound"},{"tenant_id":"globex","trunk_id":"globex-main","ingress_hosts":["globex.sip.agentvoiceruntime.com"],"called_numbers":["+49876543210"],"stt_engine":"azure","languages":["en-US"]}]
SIP_TENANT_RULES_JSON=
