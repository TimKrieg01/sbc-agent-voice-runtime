AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
# AZURE_SPEECH_ENDPOINT=wss://your-custom-endpoint (optional)

# Asterisk ARI bridge settings
ASTERISK_ARI_BASE=http://127.0.0.1:8088/ari
ASTERISK_ARI_WS=ws://127.0.0.1:8088/ari/events
ASTERISK_ARI_USER=agentic
ASTERISK_ARI_PASS=agentic-secret
ASTERISK_ARI_APP=agentic

# Local FastAPI endpoint used by ARI worker for SIP media session lifecycle
PYTHON_APP_BASE=http://127.0.0.1:8000

# Realtime config database (PostgreSQL recommended)
# Example: postgresql+psycopg://user:pass@db-host:5432/agentic_sip
SIP_CONFIG_DATABASE_URL=

# Fallback profile if dialplan does not pass tenant/stt/languages args
SIP_DEFAULT_TENANT_ID=default
SIP_DEFAULT_STT_ENGINE=azure
SIP_DEFAULT_LANGUAGES=en-US
